{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "globalSetup": "<rootDir>/utils/setup.ts",
  "globalTeardown": "<rootDir>/utils/teardown.ts",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@app/(.*)$": "<rootDir>/../src/$1"
  }
}
